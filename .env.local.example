# =============================================================================
# CompassSoenDemo — environment template
# Copy to .env.local (gitignored) and fill in real values.
# Variables are grouped by the phase they're needed in.
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 1 — Foundation (REQUIRED to boot)
# -----------------------------------------------------------------------------

# Local Postgres+pgvector via docker compose (see docker-compose.yml).
# Production DATABASE_URL is set in Railway env vars, not here.
DATABASE_URL="postgresql://compass:compass@localhost:5432/compass_dev"

# Better Auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Where Better Auth thinks it lives. localhost for dev, Railway URL for prod.
BETTER_AUTH_URL="http://localhost:3000"

# Public site URL (used in metadata, OG images, share links).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google OAuth client (from Google Cloud Console → APIs & Services → Credentials).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Admin email — used for the admin role check in middleware/admin routes.
ADMIN_EMAIL="sraldon24@gmail.com"

# -----------------------------------------------------------------------------
# Phase 3 — AI features
# -----------------------------------------------------------------------------

# Groq: https://console.groq.com/keys  (no credit card required)
GROQ_API_KEY=""

# OpenRouter — cross-provider fallback when Groq is rate-limited or down.
# Free tier: gemini-flash-1.5, llama-3.3-70b-free, deepseek-chat-free.
# Get key at: https://openrouter.ai/keys
# Behavior: app tries Groq 70B → Groq 8B → OpenRouter (in this order).
OPENROUTER_API_KEY=""

# Gemini fallback is DEFERRED for v1 — env var slot kept for easy enabling later.
# When ready: get key from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=""

# -----------------------------------------------------------------------------
# Phase 4 — Launch prep (observability, community)
# -----------------------------------------------------------------------------

# Sentry (errors): https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# PostHog (analytics): https://posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Reddit: primary content path is old.reddit.com/*.json (no key needed).
# These slots are kept for future use if we ever switch to the authenticated API.
# REDDIT_CLIENT_ID=""
# REDDIT_CLIENT_SECRET=""
# REDDIT_USER_AGENT="SOEN-Compass-Bot/1.0 (by /u/First_Emergency_5974)"

# Brave Search API (Reddit fallback + general web search for research graph).
# Get key at: https://api-dashboard.search.brave.com/app/keys
# Plan: "Search" at $5/1K requests. Free $5/mo credit = 1,000 requests/month free.
# CRITICAL: After signup, go to Usage Limits → set monthly cap to "Free" so
# overruns are rejected instead of billed.
BRAVE_SEARCH_API_KEY=""
